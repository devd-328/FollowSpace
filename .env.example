# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Phase 2 — Google Gemini extraction (server-side only)
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional — defaults to gemini-1.5-flash (broader free tier)
GEMINI_MODEL=gemini-1.5-flash
# Set to true to skip Gemini and use local mock extractor
EXTRACT_USE_MOCK=false

# Phase 5 — Resend email (server-side only)
RESEND_API_KEY=

# Phase 5 — Vercel Cron auth header
CRON_SECRET=
